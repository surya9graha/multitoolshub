{
  "hosting": {
    "public": ".",
    "appAssociation": "NONE",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      ".git",
      ".github",
      "functions/**",
      "__pycache__/**",
      "*.py",
      "*.md",
      "package.json",
      "package-lock.json"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
